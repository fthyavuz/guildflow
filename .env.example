# GuildFlow — Environment Variables
# ===================================
# Copy this file to .env and fill in the values for your environment.
# .env is gitignored and must never be committed.
#
# For local development the app can also be started with the 'dev' Spring profile
# (SPRING_PROFILES_ACTIVE=dev), which supplies safe defaults without needing this file.

# ---------------------------
# Required in production
# ---------------------------

# JWT secret — must be a cryptographically random string of at least 32 characters (256 bits).
# Generate one with: openssl rand -hex 64
APP_JWT_SECRET=your-secure-random-secret-here-minimum-32-characters

# ---------------------------
# Optional (defaults shown)
# ---------------------------

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=guildflow
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Spring profile: 'dev' or 'prod'
SPRING_PROFILES_ACTIVE=dev
